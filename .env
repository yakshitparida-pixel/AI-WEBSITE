PORT=3000

# Add only the providers you want to use.
OPENAI_API_KEY=OPENAI_API_KEY=sk-yourkeyhere
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# You can swap these models without changing the code.
OPENAI_MODEL=gpt-4.1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_MODEL=gemini-1.5-pro

# The synthesizer creates the final single answer.
# Valid values: openai, anthropic, gemini
SYNTH_PROVIDER=openai
